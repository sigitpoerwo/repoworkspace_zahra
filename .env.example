# OpenClaw Configuration Template
# Copy this file to ~/.openclaw/.env and fill in your values

# API Keys (Required)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_key_here
NVIDIA_API_KEY=your_nvidia_key_here

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=your_telegram_user_id_here

# Gateway Configuration
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_HOST=0.0.0.0

# Model Configuration
DEFAULT_MODEL=anthropic/claude-opus-4-6
DEFAULT_THINKING=high

# Workspace
OPENCLAW_WORKSPACE=~/.openclaw/workspace

# Security
OPENCLAW_AUTH_TOKEN=generate_random_token_here

# Logging
LOG_LEVEL=info
LOG_FILE=/tmp/openclaw/openclaw.log

# Optional Services
ENABLE_BROWSER=true
ENABLE_SANDBOX=true
